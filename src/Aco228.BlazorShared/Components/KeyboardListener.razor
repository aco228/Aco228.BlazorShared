@using Aco228.BlazorShared.Services
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject IJSRuntime JS

@code {
    [Inject] public IKeyboardListenerService? KeyboardListenerService { get; set; }

    private IJSObjectReference? _module;
    private DotNetObjectReference<KeyboardListener>? _dotNetRef;
    private readonly string _id = Guid.NewGuid().ToString();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || KeyboardListenerService == null) return;

        var packageId = typeof(KeyboardListener).Assembly.GetName().Name;
        var modulePath = $"./_content/{packageId}/Components/KeyboardListener.razor.js";
        _module = await JS.InvokeAsync<IJSObjectReference>("import", modulePath);
        _dotNetRef = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("register", _id, _dotNetRef);
    }

    [JSInvokable]
    public async Task<bool> HandleKeyDown(string key, bool ctrl, bool shift, bool alt)
    {
        if (KeyboardListenerService == null)
            return false;

        if (!KeyboardListenerService.Exists(shift, ctrl, key, out var shouldBePrevented))
        {
            return false;   
        }
        
        KeyboardListenerService?.TryInvoke(shift, ctrl, key).ConfigureAwait(false);
        return shouldBePrevented;
    }

    [JSInvokable]
    public async Task<List<string>> GetPreventableKeys()
    {
        if (KeyboardListenerService == null)
            return new();
        
        return KeyboardListenerService.GetPreventableKeys();
    }

    public async ValueTask DisposeAsync()
    {
        if (_module != null)
        {
            await _module.InvokeVoidAsync("unregister", _id);
            await _module.DisposeAsync();
        }
        _dotNetRef?.Dispose();
    }
    
}